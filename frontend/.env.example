# LibertyPath Frontend — copy to .env for local development
# On Vercel, set these in Project → Settings → Environment Variables

# Local backend
REACT_APP_API_URL=http://localhost:5000/api/v1

# Production (set in Vercel — replace with your Render API URL)
# REACT_APP_API_URL=https://liberty-path-api.onrender.com/api/v1

# Optional
# REACT_APP_API_TIMEOUT_MS=15000
# REACT_APP_BOOTSTRAP_TIMEOUT_MS=12000
# REACT_APP_WHATSAPP_GROUP_URL=https://chat.whatsapp.com/your-group-link
