{
  "rewrites": [
    {
      "source": "/health",
      "destination": "https://liberty-path-api.onrender.com/health"
    },
    {
      "source": "/api/:path*",
      "destination": "https://liberty-path-api.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
