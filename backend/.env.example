# LibertyPath Backend — copy to .env for local development
# On Render, set these in Dashboard → Environment (or use render.yaml)

NODE_ENV=development
HOST=127.0.0.1
PORT=5000
API_VERSION=v1

# PostgreSQL (production on Render uses DATABASE_URL from the linked database)
DATABASE_URL=postgresql://user:password@localhost:5432/libertypath
DB_DIALECT=postgres

# Or SQLite for local dev without Postgres:
# USE_SQLITE=true
# SQLITE_PATH=./database.sqlite

JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
JWT_REFRESH_EXPIRE=30d

# Frontend origin(s) for CORS — comma-separated full URLs (no trailing slash)
# Production: your Vercel URL and/or custom domain
FRONTEND_URL=http://localhost:3005
CORS_ORIGINS=
# Also allow subdomains of these suffixes (e.g. *.vercel.app, *.libertypath.site)
CORS_DOMAIN_SUFFIXES=libertypath.site,vercel.app

SERVICE_FEE_PERCENTAGE=15
MIN_WITHDRAWAL_AMOUNT=500
MAX_WITHDRAWAL_PER_WEEK=15000

BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: email / SMS
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_USER=
# EMAIL_PASS=
# SMS_API_KEY=
